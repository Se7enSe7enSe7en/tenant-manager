{
  "tailwindCSS.includeLanguages": {
    "templ": "html"
  },
  "tailwindCSS.classFunctions": [
    ".*ClassName",
  ],
  "tailwindCSS.experimental.classRegex": [
    ["[Cc]lass:\\s*\"([^\"]*)\""]
  ],
  "editor.quickSuggestions": {
    "strings": true
  },
  "emmet.includeLanguages": {
    "templ": "html"
  },
  "database-client.capitalizeKeywordsWhenFormatting": true,
}
