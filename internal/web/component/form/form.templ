package form

import (
	"encoding/json"
	"fmt"
	"github.com/Se7enSe7enSe7en/tenant-manager/internal/utils"
	"github.com/Se7enSe7enSe7en/tenant-manager/internal/web/component/label"
	"strings"
)

// SignalsWithFormId creates a SignalManager that includes formId at root level
// This allows the backend to identify which form the signals belong to
func SignalsWithFormId(formID string, signalsStruct any) *utils.SignalManager {
	// Sanitize ID by replacing hyphens with underscores for JavaScript compatibility
	sanitizedID := strings.ReplaceAll(formID, "-", "_")

	// Create signals map with formId at root level
	signalsMap := map[string]any{
		"formId":    sanitizedID,
		sanitizedID: signalsStruct,
	}

	signalsJSON, err := json.Marshal(signalsMap)
	if err != nil {
		signalsJSON = []byte("{}")
	}

	return &utils.SignalManager{
		ID:          sanitizedID,
		Signals:     signalsStruct,
		DataSignals: string(signalsJSON),
	}
}

// Form wrapper component
templ Form(args FormArgs) {
	{{
		// Set up form attributes
		var formAttrs templ.Attributes
		formAttrs = make(templ.Attributes)

		// Copy user-provided attributes first
		for k, v := range args.Attributes {
			formAttrs[k] = v
		}

		// Add form-specific attributes
		if args.ID != "" {
			formAttrs["id"] = args.ID
		}

		if args.Action != "" {
			// Check if there's a target specified in attributes
			target := ""
			if targetAttr, exists := args.Attributes["data-target"]; exists {
				target = fmt.Sprintf(", target: '%s'", targetAttr)
				// Remove data-target from attributes as we've handled it
				delete(formAttrs, "data-target")
			}

			var submitHandler string

			// If FormDataFields is set, send form data with explicit formId
			if args.FormDataFields != nil && len(args.FormDataFields) > 0 {
				// Build regex pattern to match:
				// - formId (exact match)
				// - login.email, login.password, etc. (formID.*)
				// This sends {"formId": "login", "login": {"email": "...", "password": "..."}}
				sanitizedID := strings.ReplaceAll(args.ID, "-", "_")
				filterPattern := fmt.Sprintf("^(formId|%s\\.)", sanitizedID)
				filterSignals := fmt.Sprintf("filterSignals: {include: /%s/}", filterPattern)

				if target != "" {
					submitHandler = fmt.Sprintf("@post('%s', {contentType: 'json', %s%s})", templ.SafeURL(args.Action), filterSignals, target)
				} else {
					submitHandler = fmt.Sprintf("@post('%s', {contentType: 'json', %s})", templ.SafeURL(args.Action), filterSignals)
				}
			} else {
				// Default behavior - use contentType
				contentType := "form"
				if args.ContentType == "json" {
					contentType = "json"
				}
				submitHandler = fmt.Sprintf("@post('%s', {contentType: '%s'%s})", templ.SafeURL(args.Action), contentType, target)
			}

			formAttrs["data-on-submit"] = submitHandler
			formAttrs["data-indicator-fetching"] = ""
		}

		if args.Class != "" {
			formAttrs["class"] = args.Class
		}
	}}
	<form
		{ formAttrs... }
	>
		{ children... }
	</form>
}

// FormItem component - container for form field
templ FormItem(args FormItemArgs) {
	{{ classes := formItemVariants(args.Class) }}
	<div
		data-slot="form-item"
		class={ classes }
		{ args.Attributes... }
	>
		{ children... }
	</div>
}

// FormLabel component - label for form field
templ FormLabel(args FormLabelArgs) {
	{{ classes := formLabelVariants(args.Class, args.HasError) }}
	@label.Label(label.LabelArgs{
		Class: classes,
		For:   args.For,
		Attributes: templ.Attributes{
			"data-slot":  "form-label",
			"data-error": templ.Bool(args.HasError),
		},
	}) {
		{ children... }
	}
}

// FormDescription component - help text for form field
templ FormDescription(args FormDescriptionArgs) {
	{{ classes := formDescriptionVariants(args.Class) }}
	<p
		data-slot="form-description"
		if args.ID != "" {
			id={ args.ID }
		}
		class={ classes }
		{ args.Attributes... }
	>
		{ children... }
	</p>
}

// FormMessage component - error message for form field
templ FormMessage(args FormMessageArgs) {
	if args.Message != "" {
		{{ classes := formMessageVariants(args.Class) }}
		<p
			data-slot="form-message"
			if args.ID != "" {
				id={ args.ID }
			}
			class={ classes }
			{ args.Attributes... }
		>
			if args.Message != "" {
				{ args.Message }
			} else {
				{ children... }
			}
		</p>
	}
}
