package sidebar

import "github.com/Se7enSe7enSe7en/tenant-manager/internal/utils"


// SidebarSignals defines the signal structure for sidebar components
type SidebarSignals struct {
	MobileOpen bool `json:"mobileOpen"`
}

// SidebarMobile - Sheet wrapper for mobile sidebar
templ SidebarMobile(args SidebarMobileArgs) {
	{{
		// Use parent sidebar signals directly - don't create separate sheet signals
		parentSignals := utils.Signals(args.ID, SidebarSignals{})
		sidebarHandler := NewSidebarHandler(parentSignals)
		closeHandler := sidebarHandler.BuildMobileCloseHandler()

		// Build sheet classes manually since we're not using the Sheet component
		backdropClasses := "fixed inset-0 z-50 bg-black/50 transition-opacity duration-300"
		sheetClasses := "fixed top-0 left-0 h-screen w-3/4 z-50 gap-4 bg-background shadow-lg border-r transition-opacity duration-300 sm:max-w-sm overflow-y-auto"

		// Create data-class expressions for fade animations
		backdropDataClass := utils.NewDataClass().
			Add("opacity-0", "!"+parentSignals.Signal("mobileOpen")).
			Add("opacity-100", parentSignals.Signal("mobileOpen")).
			Build()
		sheetDataClass := utils.NewDataClass().
			Add("opacity-0", "!"+parentSignals.Signal("mobileOpen")).
			Add("opacity-100", parentSignals.Signal("mobileOpen")).
			Build()

		// Create escape handler
		escapeHandler := "evt.key === 'Escape' ? (" + closeHandler + ") : null"
	}}
	<!-- Modal backdrop -->
	<div
		class={ backdropClasses }
		data-class={ backdropDataClass }
		data-show={ parentSignals.Signal("mobileOpen") }
		data-on:click={ closeHandler }
		data-on:keydown={ escapeHandler }
		style="display: none;"
	>
		<!-- Sheet content -->
		<div
			class={ sheetClasses + " w-72 p-0 bg-sidebar", args.Class }
			data-class={ sheetDataClass }
			data-on:click="evt.stopPropagation()"
			role="dialog"
			aria-modal="true"
			{ args.Attributes... }
		>
			{ children... }
		</div>
	</div>
}

// SidebarDesktop - Fixed desktop sidebar
templ SidebarDesktop(args SidebarDesktopArgs) {
	{{ classes := SidebarDesktopVariants(args) }}
	<aside
		id={ args.ID + "_desktop" }
		class={ classes }
		{ args.Attributes... }
	>
		<div class="no-scrollbar h-full overflow-auto">
			{ children... }
		</div>
	</aside>
}

// SidebarTrigger - Mobile hamburger menu button
templ SidebarTrigger(args SidebarTriggerArgs) {
	{{
		signals := utils.Signals(args.ID, SidebarSignals{})
		sidebarHandler := NewSidebarHandler(signals)
		clickHandler := sidebarHandler.BuildMobileToggleHandler()
		classes := SidebarTriggerVariants(args)
	}}
	<button
		type="button"
		class={ classes }
		data-on:click={ clickHandler }
		aria-expanded={ signals.Signal("mobileOpen") }
		{ args.Attributes... }
	>
		<!-- Hamburger icon -->
		<svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<line x1="4" x2="20" y1="12" y2="12"></line>
			<line x1="4" x2="20" y1="6" y2="6"></line>
			<line x1="4" x2="20" y1="18" y2="18"></line>
		</svg>
		<span class="sr-only">Toggle sidebar</span>
	</button>
}

// SidebarCloseButton - Close button for mobile sidebar
templ SidebarCloseButton(args SidebarCloseButtonArgs) {
	{{
		signals := utils.Signals(args.ID, SidebarSignals{})
		sidebarHandler := NewSidebarHandler(signals)
		clickHandler := sidebarHandler.BuildMobileCloseHandler()

		classes := SidebarCloseButtonVariants(args)
	}}
	<button
		type="button"
		class={ classes }
		data-on:click={ clickHandler }
		{ args.Attributes... }
	>
		<!-- X icon -->
		<svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="m18 6-12 12"></path>
			<path d="m6 6 12 12"></path>
		</svg>
		<span class="sr-only">Close sidebar</span>
	</button>
}

// SidebarContent - Shared content structure
templ SidebarContent(args SidebarContentArgs) {
	{{ classes := SidebarContentVariants(args) }}
	<div
		class={ classes }
		data-sidebar-id={ args.ID }
		{ args.Attributes... }
	>
		{ children... }
	</div>
}

