// SidebarNavMobile - Mobile navigation with sections
templ SidebarNavMobile(args SidebarNavArgs) {
	<nav class="flex flex-col gap-4">
		for _, section := range args.Sections {
			<div class="relative flex w-full min-w-0 flex-col p-2">
				<div class="flex h-8 shrink-0 items-center rounded-md px-2 text-sm text-muted-foreground font-medium">
					{ section.Title }
					if section.Label != "" {
						<span class="ml-2 rounded-md bg-[#adfa1d] px-1.5 py-0.5 text-xs leading-none text-[#000000] no-underline group-hover:no-underline">{ section.Label }</span>
					}
				</div>
				<div class="w-full text-sm">
					<ul class="flex w-full min-w-0 flex-col gap-0.5 cursor-pointer">
						for _, item := range section.Items {
							<li class="group/menu-item relative cursor-pointer">
								@SidebarNavLinkMobile(SidebarNavLinkArgs{
									SidebarID:   args.SidebarID,
									Item:        item,
									CurrentPath: args.CurrentPath,
								})
							</li>
						}
					</ul>
				</div>
			</div>
		}
	</nav>
}

// SidebarNavDesktop - Desktop navigation with sections
templ SidebarNavDesktop(args SidebarNavArgs) {
	<nav class="flex flex-col gap-4">
		for _, section := range args.Sections {
			<div class="relative flex w-full min-w-0 flex-col p-2">
				<div class="flex h-8 shrink-0 items-center rounded-md px-2 text-xs text-muted-foreground font-medium">
					{ section.Title }
					if section.Label != "" {
						<span class="ml-2 rounded-md bg-[#adfa1d] px-1.5 py-0.5 text-xs leading-none text-[#000000] no-underline group-hover:no-underline">{ section.Label }</span>
					}
				</div>
				<div class="w-full text-sm">
					<ul class="flex w-full min-w-0 flex-col gap-0.5">
						for _, item := range section.Items {
							<li class="group/menu-item relative cursor-pointer">
								@SidebarNavLinkDesktop(SidebarNavLinkArgs{
									SidebarID:   args.SidebarID,
									Item:        item,
									CurrentPath: args.CurrentPath,
								})
							</li>
						}
					</ul>
				</div>
			</div>
		}
	</nav>
}

// SidebarNavLinkMobile - Mobile nav links that close sidebar when clicked
templ SidebarNavLinkMobile(args SidebarNavLinkArgs) {
	{{
		// Nav links need to close mobile sidebar when clicked
		signals := utils.Signals(args.SidebarID, SidebarSignals{})
		sidebarHandler := NewSidebarHandler(signals)

		// Close mobile sidebar after navigation
		clickHandler := sidebarHandler.BuildMobileCloseHandler()

		classes := SidebarNavLinkMobileVariants(SidebarNavLinkArgs{
			Item:        args.Item,
			CurrentPath: args.CurrentPath,
			SidebarID:   args.SidebarID,
		})
	}}
	<a
		class={ classes }
		href={ templ.SafeURL(args.Item.Href) }
		data-on:click={ clickHandler }
	>
		{ args.Item.Title }
		if args.Item.Label != "" {
			<span class="ml-2 rounded-md bg-[#adfa1d] px-1.5 py-0.5 text-xs leading-none text-[#000000] no-underline group-hover:no-underline">{ args.Item.Label }</span>
		}
	</a>
}

// SidebarNavLinkDesktop - Desktop nav links (no click handler needed)
templ SidebarNavLinkDesktop(args SidebarNavLinkArgs) {
	{{
		classes := SidebarNavLinkDesktopVariants(SidebarNavLinkArgs{
			Item:        args.Item,
			CurrentPath: args.CurrentPath,
			SidebarID:   args.SidebarID,
		})
	}}
	<a
		class={ classes }
		href={ templ.SafeURL(args.Item.Href) }
	>
		{ args.Item.Title }
		if args.Item.Label != "" {
			<span class="ml-2 rounded-md bg-[#adfa1d] px-1.5 py-0.5 text-xs leading-none text-[#000000] no-underline group-hover:no-underline">{ args.Item.Label }</span>
		}
	</a>
}
